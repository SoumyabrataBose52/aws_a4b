# Database
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/nexus_solo

# LLM Provider: "gemini" or "mock"
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# API Security
API_KEY_SECRET=your-secret-key-for-hashing
DEFAULT_API_KEY=nexus-dev-key-12345

# App
APP_NAME=NexusSolo
APP_ENV=development
DEBUG=true

# Platform APIs
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
