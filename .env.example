# Database (local dev: full URL; production: use individual DB_* fields)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/nexus_solo
# DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
# DB_PORT=3306
# DB_NAME=nexus_solo
# DB_USER=admin
# DB_PASSWORD=your-rds-password

# LLM Provider: "bedrock" | "gemini" | "mock"
LLM_PROVIDER=mock

# AWS / Bedrock (used when LLM_PROVIDER=bedrock)
AWS_REGION=ap-south-1
BEDROCK_CRITICAL_MODEL=us.anthropic.claude-opus-4-6-20250624-v1:0
BEDROCK_FAST_MODEL=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# API Security
API_KEY_SECRET=nexus-dev-secret
DEFAULT_API_KEY=nexus-dev-key-12345

# App
APP_NAME=NexusSolo
APP_ENV=development
DEBUG=true

# Platform APIs
YOUTUBE_API_KEY=
INSTAGRAM_APP_NAME=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
